{
  "rewrites": [
    { "source": "/auth/(.*)", "destination": "http://13.206.143.211:8000/auth/$1" },
    { "source": "/dashboard/(.*)", "destination": "http://13.206.143.211:8000/dashboard/$1" },
    { "source": "/attendance/(.*)", "destination": "http://13.206.143.211:8000/attendance/$1" },
    { "source": "/face/(.*)", "destination": "http://13.206.143.211:8000/face/$1" },
    { "source": "/location/(.*)", "destination": "http://13.206.143.211:8000/location/$1" },
    { "source": "/export/(.*)", "destination": "http://13.206.143.211:8000/export/$1" },
    { "source": "/employees/(.*)", "destination": "http://13.206.143.211:8000/employees/$1" },
    { "source": "/company/(.*)", "destination": "http://13.206.143.211:8000/company/$1" },
    { "source": "/leave/(.*)", "destination": "http://13.206.143.211:8000/leave/$1" },
    {
      "source": "/((?!assets|icons|favicon.svg|icons.svg|manifest.webmanifest|service-worker.js|auth/|dashboard/|attendance/|face/|location/|export/|employees/|company/|leave/).*)",
      "destination": "/index.html"
    }
  ]
}
