{
  "rewrites": [
    { "source": "/auth/(.*)", "destination": "https://glr.taxplanadvisor.in/auth/$1" },
    { "source": "/dashboard/(.*)", "destination": "https://glr.taxplanadvisor.in/dashboard/$1" },
    { "source": "/attendance/(.*)", "destination": "https://glr.taxplanadvisor.in/attendance/$1" },
    { "source": "/face/(.*)", "destination": "https://glr.taxplanadvisor.in/face/$1" },
    { "source": "/locations/(.*)", "destination": "https://glr.taxplanadvisor.in/locations/$1" },
    { "source": "/export/(.*)", "destination": "https://glr.taxplanadvisor.in/export/$1" },
    { "source": "/employees/(.*)", "destination": "https://glr.taxplanadvisor.in/employees/$1" },
    { "source": "/company/(.*)", "destination": "https://glr.taxplanadvisor.in/company/$1" },
    { "source": "/leave/(.*)", "destination": "https://glr.taxplanadvisor.in/leave/$1" },
    { "source": "/payroll/(.*)", "destination": "https://glr.taxplanadvisor.in/payroll/$1" },
    {
      "source": "/((?!assets|icons|favicon.svg|icons.svg|manifest.webmanifest|service-worker.js|auth/|dashboard/|attendance/|face/|locations/|export/|employees/|company/|leave/|payroll/).*)",
      "destination": "/index.html"
    }
  ]
}
